{
  "name": "@equinor/eds-color-palette-generator",
  "description": "EDS Color Palette Generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "generate-colors": "./dist/cli/generate-colors.js"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:cli": "vite build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:codegen": "playwright codegen",
    "generate:palette-config-in-markdown": "tsx ./scripts/generate-palette-overview.ts",
    "generate:palette-contrast-report": "tsx ./scripts/generate-palette-contrast-report.ts",
    "types": "tsc"
  },
  "dependencies": {
    "@equinor/eds-tailwind": "workspace:^",
    "@equinor/eds-tokens": "workspace:^",
    "@equinor/eds-utils": "workspace:^",
    "colorjs.io": "^0.6.1",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@microsoft/api-extractor": "^7.58.9",
    "@next/eslint-plugin-next": "16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.0",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  }
}
